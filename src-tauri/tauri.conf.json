{
  "build": {
    "distDir": "../frontend/dist",
    "beforeBuildCommand": "",
    "devPath": "../frontend/dist",
    "beforeDevCommand": "",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Echo",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      },
      "dialog": {
        "all": true,
        "open": true
      }
    },
    "windows": [
      {
        "title": "Echo - P2P Chat",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": false,
      "identifier": "com.echo.p2p"
    }
  }
}