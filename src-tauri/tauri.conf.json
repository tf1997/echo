{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/packages/api/schema.json",
  "productName": "Echo",
  "version": "0.1.0",
  "identifier": "com.echo.p2p",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Echo - P2P Chat",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": false
  }
}