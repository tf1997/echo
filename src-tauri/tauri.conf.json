{
  "build": {
    "distDir": "../frontend/dist",
    "beforeBuildCommand": "",
    "devPath": "../frontend/dist",
    "beforeDevCommand": "",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Echo",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      },
      "window": {
        "all": true,
        "create": true
      },
      "dialog": {
        "all": true,
        "open": true
      },
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      }
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "Echo - P2P Chat",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": false,
      "identifier": "com.echo.p2p",
      "icon": [
        "icons/32x32.png",
        "icons/64x64.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper",
          "silent": true
        }
      }
    }
  }
}
